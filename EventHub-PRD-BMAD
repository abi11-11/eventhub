```sql
CREATE TABLE users (
  id UUID PRIMARY KEY,
  phone_number VARCHAR(20) UNIQUE NOT NULL,
  email VARCHAR(255) UNIQUE,
  first_name VARCHAR(100),
  last_name VARCHAR(100),
  profile_picture_url TEXT,
  bio TEXT,
  is_verified BOOLEAN DEFAULT FALSE,
  verification_date TIMESTAMP,
  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW(),
  FOREIGN KEY (id) REFERENCES user_reputation(user_id)
);
```

**Events Table**:
```sql
CREATE TABLE events (
  id UUID PRIMARY KEY,
  host_id UUID NOT NULL,
  event_type VARCHAR(100), -- 'football', 'yoga', 'cacao_ceremony', etc.
  title VARCHAR(255) NOT NULL,
  description TEXT,
  cover_image_url TEXT,
  
  -- Custom Theme
  theme_primary_color VARCHAR(7),      -- e.g., #4DB8C6
  theme_secondary_color VARCHAR(7),
  theme_text_color VARCHAR(7),
  theme_font_style VARCHAR(50),        -- 'playful', 'professional', 'elegant'
  theme_background_pattern VARCHAR(50),
  
  -- Venue & Scheduling
  venue_id UUID,                        -- Foreign key to venues
  venue_name VARCHAR(255),
  venue_address TEXT,
  latitude DECIMAL(10, 8),
  longitude DECIMAL(11, 8),
  is_online_event BOOLEAN DEFAULT FALSE,
  
  event_date DATE NOT NULL,
  start_time TIME NOT NULL,
  end_time TIME NOT NULL,
  timezone VARCHAR(50),
  is_recurring BOOLEAN DEFAULT FALSE,
  recurrence_pattern VARCHAR(100),      -- 'weekly', 'biweekly', 'monthly'
  
  -- Details
  skill_level VARCHAR(50),              -- 'beginner', 'intermediate', 'advanced', 'mixed'
  host_role VARCHAR(50),                -- 'instructor', 'coach', 'coordinator'
  min_players INT,
  max_players INT,
  age_restriction_min INT,
  age_restriction_max INT,
  gender_preference VARCHAR(50),        -- 'open', 'women_only', 'men_only', 'co_ed'
  
  -- Pricing
  entry_fee_type VARCHAR(50),           -- 'free', 'paid_per_person', 'paid_team', 'flat'
  entry_fee_amount DECIMAL(10, 2),
  currency VARCHAR(3) DEFAULT 'INR',
  platform_commission_percentage DECIMAL(5, 2) DEFAULT 10,
  
  -- Rules & Requirements
  equipment_required TEXT,
  house_rules TEXT,
  cancellation_policy TEXT,
  refund_policy TEXT,
  
  -- Status
  status VARCHAR(50),                  -- 'draft', 'published', 'live', 'completed', 'cancelled'
  created_at TIMESTAMP DEFAULT NOW(),
  updated_at TIMESTAMP DEFAULT NOW(),
  published_at TIMESTAMP,
  start_date TIMESTAMP,
  
