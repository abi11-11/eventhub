{
  "family": "eventhub-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::385080556067:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::385080556067:role/ecsTaskRole",
  "containerDefinitions": [
    {
      "name": "eventhub-api",
      "image": "PLACEHOLDER_IMAGE_URI",
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "LOG_LEVEL",
          "value": "info"
        }
      ],
      "secrets": [
        {
          "name": "DB_HOST",
          "valueFrom": "arn:aws:secretsmanager:ap-south-2:385080556067:secret:eventhub/db/host"
        },
        {
          "name": "DB_PORT",
          "valueFrom": "arn:aws:secretsmanager:ap-south-2:385080556067:secret:eventhub/db/port"
        },
        {
          "name": "DB_NAME",
          "valueFrom": "arn:aws:secretsmanager:ap-south-2:385080556067:secret:eventhub/db/name"
        },
        {
          "name": "DB_USER",
          "valueFrom": "arn:aws:secretsmanager:ap-south-2:385080556067:secret:eventhub/db/user"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-south-2:385080556067:secret:eventhub/db/password"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-south-2:385080556067:secret:eventhub/redis/url"
        },
        {
          "name": "JWT_PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-south-2:385080556067:secret:eventhub/jwt/private-key"
        },
        {
          "name": "JWT_PUBLIC_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-south-2:385080556067:secret:eventhub/jwt/public-key"
        },
        {
          "name": "FIREBASE_PROJECT_ID",
          "valueFrom": "arn:aws:secretsmanager:ap-south-2:385080556067:secret:eventhub/firebase/project-id"
        },
        {
          "name": "FIREBASE_PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-south-2:385080556067:secret:eventhub/firebase/private-key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/eventhub-api",
          "awslogs-region": "ap-south-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "curl -f http://localhost:3000/health || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ],
  "tags": [
    {
      "key": "Product",
      "value": "EventHub"
    },
    {
      "key": "Environment",
      "value": "production"
    }
  ]
}
